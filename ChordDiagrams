// ============================================================
// SVG DIAGRAM COMPONENT
// ============================================================
const ChordDiagram = ({ chord, size = "md" }) => {
  const sizes = {
    sm: { w: 78,  strFactor: 9,  fretH: 12, dotR: 4,   fontSize: 7,  titleSize: 9  },
    md: { w: 100, strFactor: 12, fretH: 16, dotR: 5.5, fontSize: 9,  titleSize: 11 },
    lg: { w: 142, strFactor: 18, fretH: 24, dotR: 8,   fontSize: 13, titleSize: 15 },
  };
  const s = sizes[size];

  const numStrings = 6;
  const numFrets = 5;
  const paddingTop = s.titleSize + 18;
  const paddingLeft = 14;
  const paddingRight = 20; // espaço para indicador de traste
  const gridW = s.strFactor * (numStrings - 1);
  const gridH = s.fretH * numFrets;
  const totalW = paddingLeft + gridW + paddingRight;
  const totalH = paddingTop + gridH + 14;

  const stringX = (i) => paddingLeft + i * s.strFactor;
  const fretY   = (f) => paddingTop + f * s.fretH;

  const { frets, fingers, baseFret, barre } = chord;

  // Converte fromString/toString (1=aguda, 6=grave) para índice SVG (0=grave/esq, 5=aguda/dir)
  // fromString=1 (E aguda) → índice 5; toString=6 (E grave) → índice 0
  const barreX1 = barre ? stringX(numStrings - barre.fromString) : 0;
  const barreX2 = barre ? stringX(numStrings - barre.toString)   : 0;
  const barreRelFret = barre ? (barre.fret - baseFret) : -1;

  return (
    <svg
      width={totalW}
      height={totalH}
      viewBox={`0 0 ${totalW} ${totalH}`}
      xmlns="http://www.w3.org/2000/svg"
    >
      {/* Nome do acorde */}
      <text
        x={(paddingLeft + paddingLeft + gridW) / 2}
        y={s.titleSize}
        textAnchor="middle"
        fontSize={s.titleSize}
        fontFamily="Georgia, serif"
        fontWeight="bold"
        fill="#000"
      >
        {chord.name}
        <tspan fontStyle="italic" fontSize={s.titleSize * 0.85}>{chord.suffix}</tspan>
      </text>

      {/* Número do traste (se > 1) */}
      {baseFret > 1 && (
        <text
          x={paddingLeft + gridW + 5}
          y={paddingTop + s.fretH * 0.78}
          fontSize={s.fontSize - 1}
          fontFamily="Arial, sans-serif"
          fill="#333"
        >
          {baseFret}ª
        </text>
      )}

      {/* Casalha / Nut — grossa só na 1ª posição */}
      <rect
        x={paddingLeft - 1}
        y={paddingTop}
        width={gridW + 2}
        height={baseFret === 1 ? 3.5 : 1}
        fill="#000"
      />

      {/* Cordas verticais */}
      {Array.from({ length: numStrings }).map((_, i) => (
        <line
          key={`s${i}`}
          x1={stringX(i)} y1={paddingTop}
          x2={stringX(i)} y2={paddingTop + gridH}
          stroke="#000" strokeWidth={0.9}
        />
      ))}

      {/* Trastes horizontais */}
      {Array.from({ length: numFrets + 1 }).map((_, f) => (
        <line
          key={`f${f}`}
          x1={paddingLeft} y1={fretY(f)}
          x2={paddingLeft + gridW} y2={fretY(f)}
          stroke="#000" strokeWidth={0.8}
        />
      ))}

      {/* Barra (cejilha de dedo) */}
      {barre && barreRelFret >= 0 && barreRelFret < numFrets && (
        <rect
          x={Math.min(barreX1, barreX2) - s.dotR}
          y={fretY(barreRelFret) + s.fretH / 2 - s.dotR}
          width={Math.abs(barreX2 - barreX1) + s.dotR * 2}
          height={s.dotR * 2}
          rx={s.dotR}
          fill="#111"
        />
      )}

      {/* X (muda) e O (solta) acima da grade */}
      {frets.map((fret, idx) => {
        const cx = stringX(idx);
        const cy = paddingTop - 8;
        if (fret === -1) {
          const d = 3.5;
          return (
            <g key={`m${idx}`}>
              <line x1={cx-d} y1={cy-d} x2={cx+d} y2={cy+d} stroke="#000" strokeWidth={1.5} strokeLinecap="round" />
              <line x1={cx+d} y1={cy-d} x2={cx-d} y2={cy+d} stroke="#000" strokeWidth={1.5} strokeLinecap="round" />
            </g>
          );
        }
        if (fret === 0) {
          return <circle key={`o${idx}`} cx={cx} cy={cy} r={3.5} fill="none" stroke="#000" strokeWidth={1.4} />;
        }
        return null;
      })}

      {/* Pontos dos dedos */}
      {frets.map((fret, idx) => {
        if (fret <= 0) return null;
        const relFret = fret - baseFret;
        if (relFret < 0 || relFret >= numFrets) return null;

        const cx = stringX(idx);
        const cy = fretY(relFret) + s.fretH / 2;
        const finger = fingers ? fingers[idx] : 0;

        // Verifica se esta corda está coberta pela barra
        // fromString=1 (E aguda/direita) → idx SVG = numStrings-1 = 5
        // toString=6  (E grave/esquerda) → idx SVG = 0
        const coveredByBarre =
          barre &&
          fret === barre.fret &&
          idx >= (numStrings - barre.fromString) &&
          idx <= (numStrings - barre.toString);

        if (coveredByBarre) {
          return finger > 0 ? (
            <text
              key={`bf${idx}`}
              x={cx} y={cy + s.fontSize * 0.38}
              textAnchor="middle"
              fontSize={s.fontSize - 1}
              fontFamily="Arial, sans-serif"
              fontWeight="bold"
              fill="#fff"
            >{finger}</text>
          ) : null;
        }

        return (
          <g key={`dot${idx}`}>
            <circle cx={cx} cy={cy} r={s.dotR} fill="#111" />
            {finger > 0 && (
              <text
                x={cx} y={cy + s.fontSize * 0.38}
                textAnchor="middle"
                fontSize={s.fontSize - 1}
                fontFamily="Arial, sans-serif"
                fontWeight="bold"
                fill="#fff"
              >{finger}</text>
            )}
          </g>
        );
      })}
    </svg>
  );
};


const SUFFIX_LABELS = {
  "": "Maior", "m": "Menor", "7": "Dom 7", "M7": "Maior 7",
  "m7": "Menor 7", "sus2": "Sus 2", "sus4": "Sus 4",
  "dim": "Diminuto", "dim7": "Dim 7", "aug": "Aumentado",
  "add9": "Add 9", "9": "Nona", "6": "Sexta", "m6": "m6",
  "m7b5": "m7♭5", "7sus4": "7sus4", "m9": "m9", "M9": "M9",
  "/E": "1ª Inv.", "/G": "2ª Inv.", "/B": "1ª Inv.", "/D": "2ª Inv.",
  "/A": "1ª Inv.", "/C": "Inv.", "/F#": "1ª Inv.", "/G#": "1ª Inv.", "/C#": "1ª Inv.",
};

const NOTE_NAMES = ["C","C#","D","D#","E","F","F#","G","G#","A","A#","B"];
const NOTE_ALT   = ["C","Db","D","Eb","E","F","Gb","G","Ab","A","Bb","B"];

// ============================================================
// APP
// ============================================================
export default function ChordDiagrams() {
  const [selectedNote, setSelectedNote] = useState("C");
  const [selectedSuffix, setSelectedSuffix] = useState(null);
  const [search, setSearch] = useState("");
  const [diagSize, setDiagSize] = useState("md");
  const [showAlt, setShowAlt] = useState(false);

  const chordsForNote = CHORDS[selectedNote] || [];

  const suffixesForNote = useMemo(() => {
    return [...new Set(chordsForNote.map(c => c.suffix))];
  }, [selectedNote]);

  const displayed = useMemo(() => {
    let list = chordsForNote;
    if (selectedSuffix !== null) list = list.filter(c => c.suffix === selectedSuffix);
    if (search.trim()) {
      const q = search.toLowerCase();
      list = list.filter(c =>
        (c.name + c.suffix).toLowerCase().includes(q) ||
        (SUFFIX_LABELS[c.suffix] || "").toLowerCase().includes(q)
      );
    }
    return list;
  }, [chordsForNote, selectedSuffix, search]);

  const totalChords = Object.values(CHORDS).reduce((a, arr) => a + arr.length, 0);

  const btn = (active, onClick, label, small = false) => (
    <button onClick={onClick} style={{
      padding: small ? "3px 7px" : "5px 10px",
      fontSize: small ? 11 : 13,
      fontWeight: active ? 800 : 500,
      background: active ? "#111" : "#fff",
      color: active ? "#fff" : "#111",
      border: `${active ? 2 : 1.5}px solid #111`,
      borderRadius: 5,
      cursor: "pointer",
      whiteSpace: "nowrap",
    }}>{label}</button>
  );

  return (
    <div style={{ fontFamily: "system-ui,sans-serif", background: "#f5f5f5", minHeight: "100vh" }}>
      {/* HEADER */}
      <div style={{
        background: "#fff", borderBottom: "2px solid #111",
        padding: "12px 14px 10px", position: "sticky", top: 0, zIndex: 10
      }}>
        <div style={{ display: "flex", alignItems: "baseline", gap: 10, marginBottom: 10 }}>
          <span style={{ fontSize: 18, fontWeight: 900, letterSpacing: -0.5 }}>🎸 Diagramas de Violão</span>
          <span style={{ fontSize: 11, color: "#888" }}>{totalChords} acordes</span>
        </div>

        {/* Notas */}
        <div style={{ display: "flex", gap: 4, flexWrap: "wrap", marginBottom: 8 }}>
          {NOTE_NAMES.map((note, i) => btn(
            selectedNote === note,
            () => { setSelectedNote(note); setSelectedSuffix(null); },
            showAlt ? NOTE_ALT[i] : note
          ))}
          <button onClick={() => setShowAlt(!showAlt)} style={{
            padding: "4px 7px", fontSize: 12, background: "#eee",
            border: "1px solid #bbb", borderRadius: 5, cursor: "pointer"
          }}>{showAlt ? "♯" : "♭"}</button>
        </div>

        {/* Sufixos */}
        <div style={{ display: "flex", gap: 3, flexWrap: "wrap", marginBottom: 8 }}>
          {btn(selectedSuffix === null, () => setSelectedSuffix(null), "Todos", true)}
          {suffixesForNote.map(suf => btn(
            selectedSuffix === suf,
            () => setSelectedSuffix(suf === selectedSuffix ? null : suf),
            suf === "" ? "M · Maior" : `${suf}${SUFFIX_LABELS[suf] ? " · " + SUFFIX_LABELS[suf] : ""}`,
            true
          ))}
        </div>

        {/* Busca + tamanho */}
        <div style={{ display: "flex", gap: 8, alignItems: "center" }}>
          <input
            value={search}
            onChange={e => setSearch(e.target.value)}
            placeholder="Buscar acorde..."
            style={{
              flex: 1, padding: "6px 10px", fontSize: 13,
              border: "1.5px solid #111", borderRadius: 5, outline: "none", background: "#fafafa"
            }}
          />
          <div style={{ display: "flex", gap: 3 }}>
            {["sm","md","lg"].map(sz => btn(diagSize === sz, () => setDiagSize(sz), sz.toUpperCase(), true))}
          </div>
        </div>
      </div>

      {/* GRID */}
      <div style={{ padding: "14px" }}>
        <div style={{ fontSize: 12, color: "#777", marginBottom: 10 }}>
          <strong style={{ color: "#111" }}>{selectedNote}</strong>
          {selectedSuffix !== null && <> · <em>{SUFFIX_LABELS[selectedSuffix] || selectedSuffix}</em></>}
          {" — "}{displayed.length} acorde{displayed.length !== 1 ? "s" : ""}
        </div>

        <div style={{
          display: "flex", flexWrap: "wrap",
          gap: diagSize === "lg" ? 18 : diagSize === "md" ? 12 : 8
        }}>
          {displayed.map((chord, i) => (
            <div key={i} style={{
              background: "#fff", border: "1px solid #ddd", borderRadius: 7,
              padding: diagSize === "lg" ? 12 : 8,
              boxShadow: "0 1px 3px rgba(0,0,0,0.06)",
              display: "flex", flexDirection: "column", alignItems: "center", gap: 3,
              transition: "box-shadow 0.15s",
            }}
              onMouseEnter={e => e.currentTarget.style.boxShadow = "0 3px 10px rgba(0,0,0,0.13)"}
              onMouseLeave={e => e.currentTarget.style.boxShadow = "0 1px 3px rgba(0,0,0,0.06)"}
            >
              <ChordDiagram chord={chord} size={diagSize} />
              {SUFFIX_LABELS[chord.suffix] && (
                <span style={{ fontSize: 9, color: "#aaa", marginTop: 1 }}>
                  {SUFFIX_LABELS[chord.suffix]}
                </span>
              )}
            </div>
          ))}
          {displayed.length === 0 && (
            <div style={{ color: "#bbb", fontSize: 14, padding: 24 }}>Nenhum acorde encontrado.</div>
          )}
        </div>
      </div>

      {/* LEGENDA */}
      <div style={{
        margin: "0 14px 24px", padding: "10px 14px",
        background: "#fff", border: "1px solid #e0e0e0", borderRadius: 7,
        fontSize: 11, color: "#666", lineHeight: 1.8
      }}>
        <strong style={{ color: "#333" }}>Legenda: </strong>
        <span>✕ = não toca</span> &nbsp;·&nbsp;
        <span>○ = corda solta</span> &nbsp;·&nbsp;
        <span>● = dedo pressionado</span> &nbsp;·&nbsp;
        <span>Número = dedo (1=indicador 2=médio 3=anelar 4=mindinho)</span> &nbsp;·&nbsp;
        <span>Barra preta = cejilha</span> &nbsp;·&nbsp;
        <span>"ª" ao lado = traste de referência</span>
      </div>
    </div>
  );
}
